# ─── Neon PostgreSQL ───────────────────────────────────────────
# Get these from your Neon project dashboard → Connection Details
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/pulsepath?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/pulsepath?sslmode=require"

# ─── NextAuth ──────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-32-char-random-string"
# Local dev — Vercel sets this automatically in production
NEXTAUTH_URL="http://localhost:3000"

# ─── Cron protection (optional) ───────────────────────────────
# If set, /api/cleanup requires: Authorization: Bearer <value>
CRON_SECRET="optional-cron-secret"

# ─── App URL ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
